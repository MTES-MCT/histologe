{% extends 'back/base_bo.html.twig' %}

{% block title %}Liste des affectations sans prise en charge{% endblock %}

{% block content %}
    <section class="fr-pt-4v">
        {% include 'back/breadcrumb_bo.html.twig' with {
            'level2Title': 'Outils SA',
            'level2Link': '',
            'level2Label': '',
            'level3Title': 'Affectations sans prise en charge',
            'level3Link': '',
        } %}

        <header>
            <div class="fr-grid-row">
                <div class="fr-col-12 fr-text--left">
                    <h1 class="fr-mb-0">Liste des affectations sans prise en charge</h1>
                </div>
            </div>
        </header>
    </section>

    {{ form_start(form) }}

    <section class="fr-col-12" aria-labelledby="filters-title">
        {% include '_partials/back/filters-title.html.twig' with {
            'skiplink_href': '#list-affectations',
            'skiplink_label': 'Accéder à la liste des affectations'
        } %}
        {{ form_errors(form) }}
        <div class="fr-grid-row fr-grid-row--bottom fr-grid-row--gutters">
            <div class="fr-col-12 fr-col-lg-4">
                {{ form_row(form.territory) }}
            </div>
            <div class="fr-col-12 fr-col-lg-4">
                {{ form_row(form.signalementStatus) }}
            </div>
            <div class="fr-col-12 fr-col-lg-4">
                <a href="{{ path('back_affectation_without_subscription_index') }}" class="fr-link fr-link--icon-left fr-icon-close-circle-line">Réinitialiser les résultats</a>
            </div>
        </div>
    </section>

    <section class="fr-col-12 fr-py-5v" id="title-list-results" aria-labelledby="desc-table">
        <div id="list-affectations">
            <h2 class="fr-mb-0" id="desc-table">{{ singular_or_plural(affectations|length, 'Affectation trouvée', 'Affectations trouvées') }}</h2>
            <div class="fr-skiplinks">
                <a class="fr-link fr-link--icon-right fr-icon-arrow-down-line" href="#pagination" aria-label="Accéder à la pagination"
                    >Accéder à la pagination</a>
            </div>
        </div>
    </section>
    
    <section class="fr-col-12 fr-col-lg-3 fr-pt-0">
        {{ form_row(form.orderType) }}
    </section>

    {{ form_end(form) }}

    <section class="fr-col-12" id="table-list-results">
        {% set tableHead %}
            <th scope="col" data-responsive-title="1">Signalement</th>
            <th scope="col">Statut du signalement</th>
            <th scope="col">Partenaire</th>
            <th scope="col">Territoires</th>
            <th scope="col">Date de création</th>
            <th scope="col" class="fr-text--right">Actions</th>
        {% endset %}
        
        {% set tableBody %}
            {% for affectation in affectations %}
                <tr class="signalement-row">
                    <td>{{ affectation.signalement.reference }}</td>
                    <td>
                        {% if affectation.signalement.statut is same as enum('App\\Entity\\Enum\\SignalementStatus').ACTIVE %}
                            <span class="fr-badge fr-badge--success fr-badge--no-icon">{{ affectation.signalement.statut.label }}</span>
                        {% else %}
                            <span class="fr-badge fr-badge--error fr-badge--no-icon">{{ affectation.signalement.statut.label }}</span>
                        {% endif %}
                    </td>
                    <td>{{ affectation.partner.nom }}</td>
                    <td>{{affectation.signalement.territory.zipAndName}}</td>
                    <td>{{ affectation.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="fr-text--right fr-ws-nowrap">
                        <a href="{{ path('back_signalement_view', {uuid: affectation.signalement.uuid}) }}"
                            class="fr-btn fr-fi-eye-line fr-btn--sm"
                            aria-label="Voir le signalement #{{ affectation.signalement.reference }}"
                            title="Voir le signalement #{{ affectation.signalement.reference }}"
                            ></a>

                        <a href="{{ path('back_partner_view', {id: affectation.partner.id}) }}"
                            class="fr-btn fr-icon-group-line fr-btn--sm"
                            aria-label="Voir le partenaire {{ affectation.partner.nom }}"
                            title="Voir le partenaire {{ affectation.partner.nom }}"
                            >{{ affectation.partner.nom }}</a>
                    </td>
                </tr>
            {% endfor %}
        {% endset %}

        {% include '_partials/back/table.html.twig' with { 'tableLabel': 'Liste des affectations sans prise en charge', 'tableHead': tableHead, 'tableBody': tableBody } %}

        <div id="pagination" class="fr-grid-row fr-mt-2v fr-grid-row--center" aria-label="Pagination de la liste des affectations">
            {% import '_partials/macros.html.twig' as macros %}
            {{ macros.customPagination(pages, searchAffectation.page, 'back_affectation_without_subscription_index', searchAffectation.urlParams) }}
        </div>
    </section>

{% endblock %}
