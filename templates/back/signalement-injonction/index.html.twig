{% extends 'back/base_bo.html.twig' %}

{% block title %}Signalements en démarche accélérée{% endblock %}

{% block content %}
    <section class="fr-pt-4v">
        {% include 'back/breadcrumb_bo.html.twig' with {
            'level2Title': 'Liste des signalements en démarche accélérée',
            'level2Link': '',
            'level2Label': ''
        } %}

        <div class="fr-notice fr-notice--warning fr-mb-3v">
            <div class="fr-container">
                <div class="fr-notice__body">
                    <p>
                        <span class="fr-notice__desc">
                            Ces signalements ne sont pas encore traités par les partenaires. Ils sont en attente d'une réponse de la part du bailleur.<br>
                            Tous ces signalements sont sur le parc privé et créés par des locataires.<br>
                            Les locataires ont accepté d'essayer de régler leur problème à l'amiable avant votre intervention.
                        </span>
                    </p>
                    <button title="Masquer le message" class="fr-btn--close fr-btn">Masquer le message</button>
                </div>
            </div>
        </div>

        <header>
            <div class="fr-grid-row">
                <div class="fr-col-12 fr-text--left">
                    <h1 class="fr-mb-0">Signalements en démarche accélérée</h1>
                </div>
            </div>
        </header>
    </section>

    {{ form_start(form) }}

    <section class="fr-col-12" aria-labelledby="filters-title">
        {% include '_partials/back/filters-title.html.twig' with {
            'skiplink_href': '#list-signalements',
            'skiplink_label': 'Passer directement à la liste des signalements'
        } %}
        {{ form_errors(form) }}
        <div class="fr-grid-row fr-grid-row--bottom fr-grid-row--gutters">        
            {% if is_granted('ROLE_ADMIN') %}
                <div class="fr-col-12 fr-col-lg-4">
                    {{ form_row(form.territoire) }}
                </div>
            {% endif %}
            <div class="fr-col-12 fr-col-lg-4">
                {{ form_row(form.reponseBailleur) }}
            </div>
            <div class="fr-col-12 fr-col-lg-4">
                {{ form_row(form.statutSignalement) }}
            </div>
            <div class="fr-col-12 fr-col-lg-4">
                <a href="{{ path('back_injonction_signalement_index') }}" class="fr-link fr-link--icon-left fr-icon-close-circle-line">Réinitialiser les résultats</a>
            </div>
        </div>
    </section>

    <section class="fr-col-12 fr-py-5v" aria-labelledby="desc-table">
        <div id="list-signalements">
            <h2 class="fr-mb-0" id="desc-table">{{ singular_or_plural(signalements|length, 'signalement trouvé', 'signalements trouvés') }}</h2>
            <div class="fr-skiplinks">
                <a class="fr-link fr-link--icon-right fr-icon-arrow-down-line" href="#pagination" aria-label="Accéder à la pagination"
                    >Accéder à la pagination</a>
            </div>
        </div>
    </section>
    
    <section class="fr-col-12 fr-col-lg-3 fr-pt-0">
        {{ form_row(form.orderType) }}
    </section>

    {{ form_end(form) }}

    <section class="fr-col-12">
        {% set tableHead %}
            {% if is_granted('ROLE_ADMIN') %}
                <th scope="col">Territoire</th>
            {% endif %}
            <th scope="col" data-responsive-title="1">Réference</th>
            <th scope="col">Date</th>
            <th scope="col">Adresse du logement</th>
            <th scope="col">Nom de l'occupant</th>
            <th scope="col">Nom du bailleur</th>
            <th scope="col">Réponse bailleur</th>
            <th scope="col">Statut de la démarche</th>
            <th scope="col">Affectations acceptées</th>
            <th scope="col">Actions</th>
        {% endset %}

        {% set tableBody %}
            {% for signalement in signalements %}
                {% set classeBadgeReponseBailleur = 'fr-badge--error' %}
                {% set labelReponseBailleur = 'Aucune' %}
                {% if signalement.suiviReponseBailleur %}
                    {% set labelReponseBailleur = signalement.suiviReponseBailleur.category.labelReponseBailleur %}
                    {% if signalement.suiviReponseBailleur.category is same as enum('App\\Entity\\Enum\\SuiviCategory').INJONCTION_BAILLEUR_REPONSE_OUI_AVEC_AIDE %}
                        {% set classeBadgeReponseBailleur = 'fr-badge--info' %}
                    {% elseif signalement.suiviReponseBailleur.category is same as enum('App\\Entity\\Enum\\SuiviCategory').INJONCTION_BAILLEUR_REPONSE_OUI
                        or signalement.suiviReponseBailleur.category is same as enum('App\\Entity\\Enum\\SuiviCategory').INJONCTION_BAILLEUR_REPONSE_OUI_DEMARCHES_COMMENCEES %}
                        {% set classeBadgeReponseBailleur = 'fr-badge--success' %}
                    {% endif %}
                {% endif %}

                {% set classeStatut = 'fr-badge--info' %}
                {% set labelStatut = 'En cours' %}
                {% if signalement.statut is same as enum('App\\Entity\\Enum\\SignalementStatus').INJONCTION_CLOSED %}
                    {% set labelStatut = 'Fermée' %}
                    {% set classeStatut = 'fr-badge--success' %}
                {% endif %}

                <tr>
                    {% if is_granted('ROLE_ADMIN') %}
                        <td>{{ signalement.territory ? signalement.territory.zipAndName : 'aucun' }}</td>
                    {% endif %}
                    <td>{{ signalement.reference }}</td>
                    <td>{{ signalement.createdAt.format('d/m/Y') }}</td>
                    <td>{{ signalement.getAddressCompleteOccupant() }}</td>
                    <td>{{ signalement.prenomOccupant ~ ' ' ~ signalement.nomOccupant }}</td>
                    <td>{{ signalement.getDisplayedNomProprio() }}</td>
                    <td><span class="fr-badge {{ classeBadgeReponseBailleur }} fr-badge--no-icon fr-ws-nowrap ">{{ labelReponseBailleur }}</span></td>
                    <td><span class="fr-badge {{ classeStatut }} fr-badge--no-icon fr-ws-nowrap ">{{ labelStatut }}</span></td>
                    <td>{{ signalement.getCountAffectationsByStatus(enum('App\\Entity\\Enum\\AffectationStatus').ACCEPTED) }} / {{ signalement.affectations|length }}</td>
                    <td>
                        <a href="{{ path('back_signalement_view', {uuid: signalement.uuid}) }}" class="fr-btn fr-fi-arrow-right-line fr-btn--sm fr-mb-1v" aria-label="Voir le signalement {{ signalement.reference }}" title="Voir le signalement {{ signalement.reference }}"></a>
                        {% if is_granted('SIGN_VIEW_INJONCTION_COURRIER', signalement) %}
                            <a href="{{ path('back_injonction_signalement_courrier_bailleur', { uuid: signalement.uuid }) }}" class="fr-btn fr-icon-mail-line fr-btn--sm" target="_blank" rel="noopener"
                                aria-label="Afficher le courrier (Ouvre une nouvelle fenêtre)" title="Afficher le courrier (Ouvre une nouvelle fenêtre)"></a>
                        {% endif %}
                        {% if is_granted('SIGN_VIEW_INJONCTION_COURRIER', signalement) and signalement.statut is same as enum('App\\Entity\\Enum\\SignalementStatus').INJONCTION_CLOSED %}
                            <a href="{{ path('back_injonction_signalement_courrier_bailleur_injonction_closed', { uuid: signalement.uuid }) }}" class="fr-btn fr-icon-mail-close-line fr-btn--sm" target="_blank" rel="noopener"
                                aria-label="Afficher le courrier de fin de procédure (Ouvre une nouvelle fenêtre)" title="Afficher le courrier de fin de procédure (Ouvre une nouvelle fenêtre)"></a>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">Aucun signalement trouvé</td>
                </tr>
            {% endfor %}
        {% endset %}

        {% include '_partials/back/table.html.twig' with { 'tableLabel': 'Liste des signalements', 'tableHead': tableHead, 'tableBody': tableBody } %}

        <div id="pagination" class="fr-grid-row fr-mt-2v fr-grid-row--center" aria-label="Pagination de la liste des signalements en injonction">
            {% import '_partials/macros.html.twig' as macros %}
            {{ macros.customPagination(pages, searchSignalement.page, 'back_injonction_signalement_index', searchSignalement.urlParams) }}
        </div>
    </section>
{% endblock %}
