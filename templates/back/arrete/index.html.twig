{% extends 'back/base_bo.html.twig' %}

{% block title %}Liste des arrêtés importés{% endblock %}

{% block content %}
    <section class="fr-pt-4v">
        {% include 'back/breadcrumb_bo.html.twig' with {
            'level2Title': 'Outils admin',
            'level2Link': '',
            'level2Label': '',
            'level3Title': 'Mon territoire',
            'level3Link': path('back_territory_management_index'),
            'level4Title': 'Liste des arrêtés importés',
            'level4Link': '',
        } %}

        <header>
            <div class="fr-grid-row">
                <div class="fr-col-12 fr-col-md-8 fr-text--left">
                    <h1 class="fr-mb-0">Arrêtés (historique importé)</h1>
                    <p>
                        Importer et consulter l'historique des arrêtés pris sur votre territoire. 
                    </p>
                </div>
                <div class="fr-col-12 fr-col-md-4 fr-text--md-right">
                    <a class="fr-btn fr-btn--icon-left fr-icon-upload-line fr-btn--block fr-btn--md-inline fr-mb-2v"
                        href="{{ path('back_arrete_import') }}"
                        title="Importer des arrêtés"
                        data-fr-opened="false"
                        >Importer des arrêtés</a>
                    <a class="fr-btn fr-btn--secondary fr-btn--icon-left fr-icon-road-map-line fr-btn--block fr-btn--md-inline"
                        href="#TODO"
                        title="Accéder à la carte"
                        data-fr-opened="false"
                        >Accéder à la carte</a>
                </div>
            </div>
        </header>
    </section>

    {{ form_start(form) }}
    <section class="fr-col-12" aria-labelledby="filters-title">
        {% include '_partials/back/filters-title.html.twig' with {
            'skiplink_href': '#list-arretes',
            'skiplink_label': 'Accéder à la liste des arrêtés importés',
        } %}
        {{ form_errors(form) }}
        <div class="fr-grid-row fr-grid-row--bottom fr-grid-row--gutters">
            {% if form.territory is defined %}
                <div class="fr-col-12 fr-col-lg-3">
                    {{ form_row(form.territory) }}
                </div>
            {% endif %}
            <div class="fr-col-12 fr-col-lg-3">

                <div class="fr-input-group">
                    {{ form_label(form.autocompleteAddress) }}
                    <div class="fr-input-wrap fr-icon-search-line">
                        {{ form_widget(form.autocompleteAddress) }}
                    </div>
					<div class="fr-address-group-container">
						<div class="fr-grid-row fr-background-alt--blue-france fr-text-label--blue-france fr-address-arrete-group fr-autocomplete-absolute">
						</div>
					</div>
                    {{ form_row(form.housenumber) }}
                    {{ form_row(form.street) }}
                    {{ form_row(form.postCode) }}
                    {{ form_row(form.city) }}
                    {{ form_row(form.cityCode) }}
                </div>
            </div>
            <div class="fr-col-12 fr-col-lg-3">
                {{ form_row(form.typeArretes) }}
            </div>
            <div class="fr-col-12 fr-col-lg-3">
                {{ form_row(form.mainLevee) }}
            </div>
            <div class="fr-col-12 fr-col-lg-3">
                <a href="{{ path('back_territory_management_arrete_index') }}" class="fr-link fr-link--icon-left fr-icon-close-circle-line">Réinitialiser les résultats</a>
            </div>
        </div>
    </section>

    <section class="fr-col-12 fr-py-5v" id="title-list-results" aria-labelledby="desc-table">
        {% include 'back/arrete/_title-list-results.html.twig' %}
    </section>
    
    <section class="fr-col-12 fr-col-lg-3 fr-pt-0">
        {{ form_row(form.orderType) }}
    </section>

    {{ form_end(form) }}

    <section class="fr-col-12" id="table-list-results">
        {% include 'back/arrete/_table-list-results.html.twig' %}
    </section>

    {% if is_granted('ROLE_ADMIN') %}
        {# Modale de suppression #}
        <div data-ajax-form>
            <dialog aria-labelledby="fr-modal-title-arrete-delete" id="fr-modal-arrete-delete" class="fr-modal">
                <div class="fr-container fr-container--fluid fr-container-md">
                    <div class="fr-grid-row fr-grid-row--center">
                        <div class="fr-col-12 fr-col-md-10 fr-col-lg-8">s
                            <div class="fr-modal__body">
                                <div class="fr-modal__header">
                                    <button class="fr-btn--close fr-btn" title="Fermer la fenêtre modale" aria-controls="fr-modal-arrete-delete">Fermer</button>
                                </div>
                                <div class="fr-modal__content">
                                    <h1 id="fr-modal-title-arrete-delete" class="fr-modal__title">
                                        Supprimer l'arrêté : <span id="fr-modal-arrete-delete-arrete-name"></span>
                                    </h1>
                                    <p>Confirmez-vous la suppression de l'arrêté ?</p>
                                    <form action="#" id="arrete_delete_form" method="POST" data-submit-type="formData">
                                        <input type="hidden" name="search_params" value="{{ app.request.query.all|url_encode }}">
                                    </form>
                                </div>
                                <div class="fr-modal__footer">
                                    <div class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg fr-btns-group--icon-left">
                                        <button class="fr-btn fr-icon-check-line" form="arrete_delete_form" type="submit">Oui, supprimer</button>
                                        <button class="fr-btn fr-btn--secondary fr-icon-close-line" type="button" aria-controls="fr-modal-arrete-delete">Non, annuler</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </dialog>
        </div>
    {% endif %}
    {# Modale de détails #}
    <div data-ajax-form>
        <dialog aria-labelledby="fr-modal-title-arrete-details" id="fr-modal-arrete-details" class="fr-modal">
            <div class="fr-container fr-container--fluid fr-container-md">
                <div class="fr-grid-row fr-grid-row--center">
                    <div class="fr-col-12 fr-col-md-10 fr-col-lg-8">
                        <div class="fr-modal__body">
                            <div class="fr-modal__header">
                                <button class="fr-btn--close fr-btn" title="Fermer la fenêtre modale" aria-controls="fr-modal-arrete-details">Fermer</button>
                            </div>
                            <div class="fr-modal__content">
                                <h1 id="fr-modal-title-arrete-details" class="fr-modal__title">
                                    Détails de l'arrêté : <span id="fr-modal-arrete-details-arrete-name"></span>
                                </h1>
                                {% for arrete in arretes %}
                                    <div id="fr-modal-arrete-details-{{ arrete.id }}" class="item-arrete-details">
                                        {% if arrete.importedAt %}
                                            <p>
                                                <i>Importé le {{ arrete.importedAt|date('d/m/Y') }}</i>
                                                {% if arrete.createdBy %}
                                                    <i> par {{ arrete.createdBy.nomComplet }}</i>
                                                {% endif %}
                                            </p>
                                            <h2>Arrêté</h2>
                                            <ul>
                                                <li>Date : {{ arrete.dateArrete|date('d/m/Y') }}</li>
                                                <li>Type : {{ arrete.typeArrete.label }}</li>
                                                <li>Main levée : {% if arrete.mainLevee %}Oui{% endif %}</li>
                                                <li>Date de la main levée : {% if arrete.dateMainLevee %}{{ arrete.dateMainLevee|date('d/m/Y') }}{% endif %}</li>
                                            </ul>
                                            <h2>Adresse</h2>
                                            <ul>
                                                <li>Adresse : {{ arrete.address.housenumber }} {{ arrete.address.street }}</li>
                                                <li>Code postal : {{ arrete.address.postcode }}</li>
                                                <li>Commune : {{ arrete.address.city }}</li>
                                                <li>Code INSEE : {{ arrete.address.cityCode }}</li>
                                                <li>Syndicat / gestionnaire : {{ arrete.syndic }}</li>
                                                <li>Identifiant parcellaire : {{ arrete.identifiantParcellaire }}</li>
                                            </ul>
                                        {% endif %}
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </dialog>
    </div>

{% endblock %}
