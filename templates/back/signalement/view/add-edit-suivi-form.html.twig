{{ form_start(form, {'attr': {'id': formId, 'data-submit-type':'formData'}}) }}
    <div class="fr-input-group">
        <span class="no-field-errors"></span>
    </div>
    {{ form_errors(form) }}
    {% if show_email_alert(signalement.mailDeclarant) and show_email_alert(signalement.mailOccupant) %}
        <p class="fr-badge fr-badge--error">L'adresse e-mail de l'usager n'est pas valide. Vous ne pouvez pas lui envoyer le suivi.</p>
    {% endif %}
    <div class="fr-mb-3w">
        <div class="fr-label fr-mb-2v">Destinataires du message</div>
        {{ form_row(form.isVisibleForUsager) }}
        {% if form.isVisibleForBailleur is defined %}
            {{ form_row(form.isVisibleForBailleur) }}
        {% endif %}
        {{ form_row(form.isVisibleForPartners) }}
    </div>
    <div class="fr-mb-3w">
        {{ form_row(form.description) }}
    </div>
    <div class="fr-mb-3w">
        {{ form_row(form.files) }}
    </div>
{{ form_end(form) }}