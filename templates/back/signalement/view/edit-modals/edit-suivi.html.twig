<dialog aria-labelledby="panel-edit-suivi-title" id="panel-edit-suivi" class="side-panel">
    <div class="side-panel__inner">
        <div class="side-panel__header">
            <button type="button" class="fr-btn--close fr-btn js-close-panel" data-panel="panel-edit-suivi" aria-controls="panel-edit-suivi" aria-expanded="false">Fermer</button>
        </div>
        <div class="side-panel__content fr-mx-3w">
            <h1 id="panel-edit-suivi-title" class="fr-modal__title title-blue-france">Modifier le suivi</h1>
            <div id="panel-edit-suivi-form-container">Chargement en cours...</div>
        </div>
        <div class="side-panel__footer">
            <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg fr-btns-group--icon-left">
                <li>
                    <button class="fr-btn fr-icon-check-line" form="panel-edit-suivi-form" type="submit">
                        Valider
                    </button>
                </li>
                <li>
                    <button class="fr-btn fr-btn--secondary fr-icon-close-line js-close-panel" data-panel="panel-edit-suivi" aria-controls="panel-edit-suivi" aria-expanded="false" type="button">
                        Annuler
                    </button>
                </li>
            </ul>
        </div>
    </div>
</dialog>