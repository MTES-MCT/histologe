{% set columns = [
    { class: 'fr-col-md-4', title: 'Référence' },
    { class: 'fr-col-md-3', title: 'Nombre de partenaires en attente' },
    { class: 'fr-col-md-2', title: 'Dernière affectation' },
    { class: 'fr-col-md-2', title: 'Parc' },
] %}
<section class="fr-mb-5v">
    <header class="fr-grid-row fr-grid-row--gutters">
        <div class="fr-col-12 fr-col-md-9">
            <h3 class="fr-text-label--blue-france tab-panel-title-with-connection-lost-icon">Dossier en attente ({{ count }})</h3>
            <div class="fr-text--sm fr-mb-3v">Aperçu des 5 derniers dossiers affectés mais sans aucun partenaire actif (en attente ou refusé)</div>
        </div>
        <div class="fr-select-group fr-col-12 fr-col-md-3">
            <label class="fr-label" for="order-type-dossiers-sans-affectation-acceptee">
                Trier par
            </label>
            <select id="order-type-dossiers-sans-affectation-acceptee" class="fr-select" data-sort-body="dossiers-sans-affectation-acceptee">
                <option value="affectedAt-ASC" selected="selected">Affectation la plus ancienne (de la plus ancienne à la plus récente) = tri par défaut</option>
                <option value="affectedAt-DESC">Affectation la plus récente (du plus récent au plus ancien)</option>
                <option value="nomOccupant-ASC">Ordre alphabétique (A > Z)</option>
                <option value="nomOccupant-DESC">Ordre alphabétique (Z > A)</option>
            </select>
        </div>
    </header>
    <hr class="hr--blue-france">
    <section class="fr-container--fluid">
        {% for item in items %}
            {% set occupantInfo = item.reference ~ ' - ' ~ item.nomOccupant|upper ~ ' ' ~ item.prenomOccupant|capitalize %}
            {% include 'back/dashboard/components/_card.html.twig' with {
                data: [
                    '<div class="fr-text-label--blue-france">
                            <div><strong class="fr-text--lg">' ~ occupantInfo ~ '</strong></div>
                            <div>' ~ item.adresse ~ '</div>
                        </div>',
                    '<div><span class="fr-badge fr-badge--info fr-badge--no-icon">' ~ item.nbAffectations  ~ '</span></div>',
                    
                    '<div>le ' ~ item.derniereAffectationAt|date('d/m/Y à H:i') ~ '</div>',

                    '<span class="fr-badge fr-badge--info fr-badge--no-icon">' ~ item.parc ~ '</span>'
                ],
                link: path('back_signalement_view', {'uuid' : item.uuid})
            } %}
        {% else %}
            <p>Aucun dossier trouvé.</p>
        {% endfor %}
        {% if count > MAX_ITEMS_LIST %}
            {% set paramsSansPartenaires = filters|merge({'partenaires': null}) %}
            {% set url = path('back_signalements_index', paramsSansPartenaires) %}
            {% if filters.partenaires is defined and filters.partenaires|length %}
                {% set url = url ~ (('?' in url) ? '&' : '?') %}
                {% for id in filters.partenaires %}
                    {% set url = url ~ 'partenaires[]=' ~ id ~ (not loop.last ? '&' : '') %}
                {% endfor %}
            {% endif %}
            <div class="fr-text--right">
                <a href="{{ url }}" class="fr-text-label--blue-france">
                Afficher la liste complète<span class="fr-fi-arrow-right-line"></span>
                </a>
            </div>
        {% endif %}
    </section>
</section>
