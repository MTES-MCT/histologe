<dialog aria-labelledby="fr-modal-profil-notification-email-title" id="fr-modal-profil-notification-email" class="fr-modal">
    <div class="fr-container fr-container--fluid fr-container-md">
        <div class="fr-grid-row fr-grid-row--center">
            <div class="fr-col-12 fr-col-md-8 fr-col-lg-6">
                <div class="fr-modal__body">
                    <div class="fr-modal__header">
                        <button type="button" class="fr-btn--close fr-btn" aria-controls="fr-modal-profil-notification-email">Fermer</button>
                    </div>
                    <div class="fr-modal__content">
                        <h1 id="fr-modal-profil-notification-email-title" class="fr-modal__title">
                            Paramétrer mes notifications e-mails
                        </h1>
                        <p>
                            Choisissez vos préférences en matière de notifications par e-mails.
                        </p>
                        {{form_start(notificationEmailForm, {'attr': {'id': 'notification_email_form', 'data-submit-type':'formData'}} )}}    
                        <h2 class="fr-h5">Activité sur {{ platform.name }}</h2>
                        <p>
                            Il s'agit des e-mails concernant l'activité sur les signalements. 
                            Choisissez entre un e-mail à chaque nouveauté ou un e-mail récapitulatif quotidien. 
                            <br>
                            NB : s'il n'y a pas de nouvelle activité sur vos signalements, vous ne recevrez pas d'e-mail récapitulatif !
                        </p>
                        {{form_row(notificationEmailForm.isMailingSummary)}}
                        <div id="modal-profil-notification-email-alert-signalement">
                            {% include 'back/profil/_modal_profil_notification_email_alert_signalement.html.twig' %}
                        </div>
                        <h2 class="fr-h5 fr-mt-3w">Prochains clubs utilisateurs</h2>
                        <p>
                            Il s'agit des e-mails concernant les club utilisateurs à venir pour votre profil.
                        </p>
                        {{form_row(notificationEmailForm.isMailingClubEvent)}}
                        {{form_end(notificationEmailForm)}}
                    </div>
                    <div class="fr-modal__footer">
                        <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg fr-btns-group--icon-left">
                            <li>
                                <button class="fr-btn fr-icon-check-line" form="notification_email_form" type="submit">
                                    Valider
                                </button>
                            </li>
                            <li>
                                <button class="fr-btn fr-btn--secondary fr-icon-close-line" aria-controls="fr-modal-profil-notification-email" type="button">
                                    Annuler
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</dialog>