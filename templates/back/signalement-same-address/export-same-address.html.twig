{% extends 'back/base_bo.html.twig' %}

{% block title %}Export des dossiers à la même adresse{% endblock %}

{% block content %}
    <section class="fr-pt-4v">
        {% include 'back/breadcrumb_bo.html.twig' with {
            'level2Title': 'Dossiers à la même adresse',
            'level2Link': path('back_signalement_same_address_index', app.request.query.all),
            'level2Label': '',
            'level3Title': 'Export',
            'level3Link': '',
            'level3Label': '',
        } %}

        <header>
            <div class="fr-grid-row">
                <div class="fr-col-12 fr-text--left">
                    <h1>Exporter les {{ nbResults }} dossiers à la même adresse</h1>
                    <p>
                        Vous êtes sur le point d'exporter les dossiers à la même adresse.
                        <br>
                        Choisissez le format de fichier que vous souhaitez recevoir.
                    </p>
                </div>
            </div>
        </header>
    </section>

    <section class="fr-pt-4v">
        <h2>Filtres actifs</h2>
        <div class="fr-mb-3v">
            Votre liste contient {{ nbResults }} dossiers. Les filtres suivants sont actifs :
        </div>
        {% for filterName, filterValue in filtersText %}
            <p class="fr-badge">{{ filterName }} : {{ filterValue }}</p>
        {% else %}
            Aucun filtre actif.
        {% endfor %}
    </section>

    <section class="fr-pt-4v">
        <form action="" method="POST" id="export-same-address">
            <h2>Format</h2>
            {% include 'form/form-choice-export-format.html.twig' %}
        </form>

        <h2 class="fr-mt-5v">Informations du fichier</h2>
        <div class="fr-alert fr-alert--warning fr-alert--sm">
            <p>Les informations contenues dans ce fichier ne doivent en aucun cas être partagées en dehors de vos services.</p>
        </div>
        <p class="fr-mt-5v">
            Votre fichier contient les informations suivantes :
        </p>
        <ul>
            {% if isMultiTerritory %}                
                <li><strong>Territoire</strong> : le territoire du dossier</li>
            {% endif %}
            <li><strong>Référence du dossier</strong> : la référence du dossier</li>
            <li><strong>Nom / prénom de l'occupant</strong> : le nom et le prénom de l'occupant</li>
            <li><strong>Adresse postale</strong> : l'adresse du logement</li>
            <li><strong>Code postal</strong> : le code postal du logement</li>
            <li><strong>Commune</strong> : la commune du logement</li>
            <li><strong>Statut du dossier</strong> : le statut du dossier</li>
            <li><strong>Date de création du dossier</strong> : la date de création du dossier</li>
            <li><strong>Date de fermeture du dossier</strong> : la date de fermeture du dossier</li>
        </ul>
        <ul class="fr-col-12 fr-btns-group fr-btns-group--inline-lg fr-btns-group--right fr-btns-group--icon-left">
            <li>
                <a href="{{ path('back_signalement_same_address_index') }}" class="fr-btn fr-w-100 fr-btn--secondary fr-btn--icon-left fr-icon-close-line">
                    Annuler
                </a>
            </li>
            <li>
                <button type="submit" form="export-same-address" class="fr-btn fr-w-100 fr-btn--icon-left fr-icon-check-line">
                    Exporter le fichier
                </button>
            </li>
        </ul>
    </section>

{% endblock %}
