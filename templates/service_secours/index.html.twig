{% extends 'service_secours/base.html.twig' %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('build/leaflet/leaflet.css')}}">
{% endblock %}

{% block body %}
    <main class="fr-container fr-mb-5w" id="content">
        {% set current_step = form.vars.cursor.currentStep %}
        {% if current_step == 'step2' %}
            <dialog 
                aria-labelledby="fr-modal-pick-localisation-title" 
                id="fr-modal-pick-localisation" 
                class="fr-modal" 
                data-address="{{form.step2.adresseOccupant.vars.value}}"
                data-postcode="{{form.step2.cpOccupant.vars.value}}"
                data-loaded="false"
                >
                <div class="fr-container fr-container--fluid fr-container-md">
                    <div class="fr-grid-row fr-grid-row--center">
                        <div class="fr-col-12 fr-col-md-8 fr-col-lg-6">
                            <div class="fr-modal__body">
                                <div class="fr-modal__header">
                                <button type="button" class="fr-btn--close fr-btn" aria-controls="fr-modal-pick-localisation">Fermer</button>
                                </div>
                                <div class="fr-modal__content">
                                    <h1 class="fr-modal__title">Sélectionner le bâtiment correspondant au logement</h1>  
                                    <div id="fr-modal-pick-localisation-message">Chargement en cours</div>
                                    <div id="fr-modal-pick-localisation-map"></div>
                                </div>
                                <input type="hidden" name="rnbId" id="fr-modal-pick-localisation-rnb-id">
                                <input type="hidden" name="_token" id="fr-modal-pick-localisation-token" value="{{ csrf_token('service_secours_set_rnb') }}">
                                <div class="fr-modal__footer">
                                    <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-lg fr-btns-group--icon-left">
                                        <li>
                                            <button class="fr-btn fr-icon-check-line" id="fr-modal-pick-localisation-submit" disabled type="button">
                                                Valider
                                            </button>
                                        </li>
                                        <li>
                                            <button type="button" class="fr-btn fr-btn--secondary fr-icon-close-line" aria-controls="fr-modal-pick-localisation">
                                                Annuler
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </dialog>
        {% endif %}
        <section class="fr-grid-row fr-grid-row--center">
            <div class="fr-mt-5v fr-col-md-12">
                {% if current_step === 'step1' %}
                    {% set step_number = 1 %}
                    {% set step_title = 'Vos coordonnées' %}
                    {% set next_step_title = 'Infos sur le logement' %}
                {% elseif current_step === 'step2' %}
                    {% set step_number = 2 %}
                    {% set step_title = 'Infos sur le logement' %}
                    {% set next_step_title = 'Occupation du logement' %}
                {% elseif current_step === 'step3' %}
                    {% set step_number = 3 %}
                    {% set step_title = 'Occupation du logement' %}
                    {% set next_step_title = 'Propriétaire / bailleur' %}
                {% elseif current_step === 'step4' %}
                    {% set step_number = 4 %}
                    {% set step_title = 'Propriétaire / bailleur' %}
                    {% set next_step_title = 'Désordres' %}
                {% elseif current_step === 'step5' %}
                    {% set step_number = 5 %}
                    {% set step_title = 'Désordres' %}
                {% endif %}

                {% if current_step != 'step6' %}
                    <div class="fr-stepper">
                        <h1 class="fr-stepper__title">
                            {{step_title}} <span class="fr-stepper__state">Étape {{ step_number }} sur 5</span>
                        </h1>
                        <div class="fr-stepper__steps" data-fr-current-step="{{ step_number }}" data-fr-steps="5"></div>
                        {% if next_step_title is defined %}
                            <p class="fr-stepper__details">
                                <span class="fr-text--bold">Étape suivante :</span> {{ next_step_title }}
                            </p>
                        {% endif %}
                    </div>
                {% endif %}

                {{ form_start(form, {'attr': {'id': 'fo-form-service-secours'}}) }}
                {# Afficher uniquement les erreurs globales du formulaire, pas celles des champs individuels #}
                {% for error in form.vars.errors %}
                    {% if error.origin is same as(form) %}
                    <div class="fr-alert fr-alert--error fr-mb-2w">
                        <p>{{ error.message }}</p>
                    </div>
                    {% endif %}
                {% endfor %}

                {% if current_step == 'step1' %}
                    <h2 class="fr-h5">Vos coordonnées</h2>
                    {{ form_row(form.step1.matriculeDeclarant) }}
                    {{ form_row(form.step1.nomDeclarant) }}
                    {{ form_row(form.step1.dateMission) }}
                    {{ form_row(form.step1.origineMission) }}
                    {{ form_row(form.step1.ordreMission) }}
                {% elseif current_step == 'step2' %}
                    {{ form_row(form.step2.adresseCompleteOccupant) }}
                    <input
                            type="hidden"
                            id="signalement_draft_address_filterSearchAddressTerritory"
                            value="{{ serviceSecoursRoute.territory.zip }}|{{ serviceSecoursRoute.territory.name }}"
                    />
                    <div id="fo-form-service-secours-adresse">
                        <div class="fr-grid-row fr-background-alt--blue-france fr-text-label--blue-france fr-address-group">
                        </div>
                    </div>
                    <div class="fr-my-2w">
                        <button type="button" class="fr-link fr-link--icon-left fr-icon-edit-line manual-address-switcher">Saisir une adresse manuellement</button>
                    </div>
				    <div class="fr-hidden fr-mb-2w manual-address-container">
                        {{ form_row(form.step2.adresseOccupant) }}
                        {{ form_row(form.step2.cpOccupant) }}
                        {{ form_row(form.step2.villeOccupant) }}
                        {{ form_row(form.step2.inseeOccupant) }}
                        {{ form_widget(form.step2.rnbId) }}
                        <button 
                            type="button"
                            class="fr-btn fr-btn--sm fr-btn--icon-left fr-icon-map-pin-2-line btn-pick-localisation fr-hidden" 
                            data-fr-opened="false" 
                            aria-controls="fr-modal-pick-localisation"
                            >
                            Sélectionner le bâtiment sur la carte
                        </button>
                        <span class="fr-hidden pick-location-success fr-ml-2v" id="pick-location-success"><span class="fr-icon-check-line" aria-hidden="true"></span> Bâtiment sélectionné </span>
                    </div>
                    {{ form_row(form.step2.adresseAutreOccupant) }}
					{{ form_row(form.step2.isLogementSocial, {display_mode: 'block'}) }}
                    {{ form_row(form.step2.natureLogement, {display_mode: 'block'}) }}
                    <div class="fr-hidden nature-logement-autre-container fr-input-group">
                        {{ form_row(form.step2.natureLogementAutre) }}
                    </div>
                    <div class="fr-hidden type-etage-logement-appartement-container fr-input-group">
                        {{ form_row(form.step2.typeEtageLogement, {display_mode: 'block'}) }}
                        <div class="fr-hidden etage-occupant-container fr-input-group fr-pl-4w">
                            {{ form_row(form.step2.etageOccupant) }}
                        </div>
                    </div>
                    {{ form_row(form.step2.nbPiecesLogement) }}
                    {{ form_row(form.step2.superficie) }}
                {% elseif current_step == 'step3' %}
                    <h2 class="fr-h5">Coordonnées de l'occupant</h2>
                    {{ form_row(form.step3.profilOccupant, {display_mode: 'block'}) }}
                    {{ form_row(form.step3.nomOccupant) }}
                    {{ form_row(form.step3.prenomOccupant) }}
                    {{ form_row(form.step3.mailOccupant) }}
                    {{ form_row(form.step3.telOccupant) }}
                    <h2 class="fr-h5">Situation du foyer</h2>
                    {{ form_row(form.step3.nbAdultesDansLogement) }}
                    {{ form_row(form.step3.nbEnfantsDansLogement) }}
                    {{ form_row(form.step3.isEnfantsMoinsSixAnsDansLogement, {display_mode: 'block'}) }}
                    {{ form_row(form.step3.autreVulnerabilite) }}
                {% elseif current_step == 'step4' %}
                    {% if form.step4.isBailleurAverti is defined %}
                        <h2 class="fr-h5">Informations sur le bailleur</h2>
                        {{ form_row(form.step4.isBailleurAverti, {display_mode: 'block'}) }}
                    {% endif %}
                    {% if form.step4.denominationProprio is defined %}
                        <div class="fr-input-group">
                            {{ form_label(form.step4.denominationProprio) }}
                            {{ form_widget(form.step4.denominationProprio) }}
                            <ul class="fr-grid-row fr-background-alt--blue-france fr-text-label--blue-france fr-autocomplete-list">
                            </ul>
                        </div>
                    {% endif %}
                    {% if form.step4.nomProprio is defined %}
                        {{ form_row(form.step4.nomProprio) }}
                    {% endif %}
                    {% if form.step4.prenomProprio is defined %}
                        {{ form_row(form.step4.prenomProprio) }}
                    {% endif %}
                    {% if form.step4.mailProprio is defined %}
                        {{ form_row(form.step4.mailProprio) }}
                    {% endif %}
                    {% if form.step4.telProprio is defined %}
                        {{ form_row(form.step4.telProprio) }}
                    {% endif %}
                    {% if form.step4.isBailleurAverti is defined %}
                    <div class="fr-my-2w">
                        <button type="button" class="fr-link fr-link--icon-left fr-icon-add-line" id="show-informations-syndic-container">Ajouter les coordonnées du syndic</button>
                    </div>
                    {% endif %}
                    <div class="{% if form.step4.isBailleurAverti is defined %}fr-hidden{% endif %} fr-mb-3w" id="informations-syndic-container">
                        <h2 class="fr-h5">Informations sur le syndic</h2>
                        {{ form_row(form.step4.denominationSyndic) }}
                        {{ form_row(form.step4.nomSyndic) }}
                        {{ form_row(form.step4.mailSyndic) }}
                        {{ form_row(form.step4.telSyndic) }}
                        {{ form_row(form.step4.telSyndicSecondaire) }}
                    </div>
                {% elseif current_step == 'step5' %}
                    {{ form_row(form.step5.desordres) }}
                    {{ form_row(form.step5.desordresAutre) }}
                    {% if form.step5.autresOccupantsDesordre is defined %}
                        {{ form_row(form.step5.autresOccupantsDesordre, {display_mode: 'block'}) }}
                    {% endif %}
                    <div
                            class="fr-upload-group js-upload-photos"
                            data-ajaxurl-handle-upload="{{ path('handle_upload') }}">
                        <p class="fr-text--lg">
                            <span class="fr-text--bold">Photos</span><br>
                            <span>Si possible, ajoutez des photos des problèmes sélectionnés.</span>
                        </p>

                        {% if form.step5.photos.vars.help %}
                            <span class="fr-hint-text fr-mb-2w">{{ form.step5.photos.vars.help }}</span>
                        {% endif %}
                        <button
                                type="button"
                                class="fr-btn fr-btn--secondary fr-btn--icon-left fr-icon-add-line"
                                data-upload-photos-trigger>
                            Ajouter des photos
                        </button>

                        <div class="fr-hidden">
                            {{ form_widget(form.step5.photos, {
                                attr: {
                                    'data-upload-photos-input': '',
                                    'accept': 'image/jpeg,image/png,image/gif,application/pdf'
                                }
                            }) }}
                        </div>

                        {{ form_errors(form.step5.photos) }}
                        <div class="fr-mt-2w" data-upload-photos-list></div>
                        <div data-upload-photos-hidden-container
                             data-input-name="{{ form.step5.uploadedFiles.vars.full_name }}"
                             data-uploaded-files='{{ form.step5.vars.data.uploadedFiles|json_encode|e("html_attr") }}'
                        >

                        </div>
                        {% do form.step5.uploadedFiles.setRendered %}

                    </div>
                {% elseif current_step == 'step6' %}
                    <div class="fr-mt-5v fr-mb-5v">
                        <h1 class="fr-h5">Récapitulatif et validation</h1>
                        <div>Vérifiez les informations saisies puis validez le signalement.</div>
                    </div>
                    
                    <div class="signalement-group-data-card">
                        <div class="fr-display-flex-row fr-justify-content-space-between fr-align-items-center">
                            <h2 class="fr-h6">Vos coordonnées</h2>
                            {{ form_row(form.navigator.editStep1) }}
                        </div>
                        {% if data.step1.matriculeDeclarant %}
                            Matricule : {{ data.step1.matriculeDeclarant }}<br>
                        {% endif %}
                        {% if data.step1.nomDeclarant %}
                            Nom : {{ data.step1.nomDeclarant }}<br>
                        {% endif %}
                        {% if data.step1.dateMission %}
                            Date de la mission : {{ data.step1.dateMission|format_datetime(locale='fr', timezone=territory_timezone, pattern='d MMMM yyyy') }}<br>
                        {% endif %}
                        {% if data.step1.origineMission %}
                            Engin à l'origine du signalement : {{ data.step1.origineMission }}<br>
                        {% endif %}
                        {% if data.step1.ordreMission %}
                            Ordre de la mission : {{ data.step1.ordreMission }}<br>
                        {% endif %}
                    </div>
                    
                    <div class="signalement-group-data-card">
                        <div class="fr-display-flex-row fr-justify-content-space-between fr-align-items-center">
                            <h2 class="fr-h6">Infos sur le logement</h2>
                            {{ form_row(form.navigator.editStep2) }}
                        </div>
                        {{ data.step2.adresseOccupant }} <br>
                        {% if data.step2.adresseAutreOccupant %}
                            {{ data.step2.adresseAutreOccupant }}<br>
                        {% endif %}
                        {{ data.step2.cpOccupant }} {{ data.step2.villeOccupant }}<br>
                        {% if data.step2.isLogementSocial %}
                            Logement social : {{ data.step2.isLogementSocial|format_answer }}<br>
                        {% endif %}
                        {% if data.step2.natureLogement %}
                            Nature du logement : {{ data.step2.natureLogement }}
                            {% if  data.step2.natureLogement is same as 'autre' and data.step2.natureLogementAutre %}
                                ({{ data.step2.natureLogementAutre }})
                            {% endif %}
                            <br>
                        {% endif %}
                        {% if data.step2.typeEtageLogement is not null %}
                            Etage : {{ data.step2.typeEtageLogement.label }}
                            {% if data.step2.typeEtageLogement is same as enum('\\App\\Entity\\Enum\\EtageType').AUTRE and data.step2.etageOccupant %}
                                ({{ data.step2.etageOccupant }})
                            {% endif %}
                            <br>
                        {% endif %}
                        {% if data.step2.nbPiecesLogement %}
                             Nombre de pièces à vivre : {{ data.step2.nbPiecesLogement }}<br>
                        {% endif %}
                        {% if data.step2.superficie %}
                            Superficie : {{ data.step2.superficie }} m²<br>
                        {% endif %}
                    </div>
                    
                    <div class="signalement-group-data-card">
                        <div class="fr-display-flex-row fr-justify-content-space-between fr-align-items-center">
                            <h2 class="fr-h6">Occupation du logement</h2>
                            {{ form_row(form.navigator.editStep3) }}
                        </div>
                        {% if data.step3.nomOccupant %}
                            {{ data.step3.nomOccupant }} 
                            {% if data.step3.prenomOccupant %}
                                {{ data.step3.prenomOccupant }}
                            {% endif %}
                            <br>
                        {% endif %}
                        {% if data.step3.profilOccupant and data.step3.profilOccupant is not same as 'indetermine' %}
                            {% if data.step3.profilOccupant is same as 'logement_vacant' %}
                                Logement vacant<br>
                            {% else %}
                                {% set ProfilOccupant = enum('\\App\\Entity\\Enum\\ProfileOccupant') %}
                                {{ ProfilOccupant.from(data.step3.profilOccupant).label }}<br>
                            {% endif %}
                        {% endif %}
                        {% if data.step3.mailOccupant %}
                            {{ data.step3.mailOccupant }}<br>
                        {% endif %}
                        {% if data.step3.telOccupant %}
                            {{ data.step3.telOccupant }}<br>
                        {% endif %}
                        {% if data.step3.nbAdultesDansLogement %}
                            {{ singular_or_plural(data.step3.nbAdultesDansLogement, 'adulte', 'adultes') }}<br>
                        {% endif %}
                        {% if data.step3.nbEnfantsDansLogement %}
                            {{ singular_or_plural(data.step3.nbEnfantsDansLogement, 'mineur', 'mineurs') }}<br>
                        {% endif %}
                        {% if data.step3.isEnfantsMoinsSixAnsDansLogement %}
                             Mineurs de 6 ans ou moins : {{ data.step3.isEnfantsMoinsSixAnsDansLogement|format_answer }}<br>
                        {% endif %}
                        {% if data.step3.autreVulnerabilite %}
                            Autre situation de vulnérabilité : {{ data.step3.autreVulnerabilite }}<br>
                        {% endif %}
                    </div>
                    
                    <div class="signalement-group-data-card">
                        <div class="fr-display-flex-row fr-justify-content-space-between fr-align-items-center">
                            <h2 class="fr-h6">Propriétaire / Syndic</h2>
                            {{ form_row(form.navigator.editStep4) }}
                        </div>
                        {% set showBailleur = data.step4.isBailleurAverti or data.step4.denominationProprio or data.step4.nomProprio or data.step4.prenomProprio or data.step4.mailProprio or data.step4.telProprio %}
                        {% set showSyndic = data.step4.denominationSyndic or data.step4.nomSyndic or data.step4.mailSyndic or data.step4.telSyndic or data.step4.telSyndicSecondaire %}
                        {% if showBailleur %}                            
                            <strong>Propriétaire / Bailleur</strong><br>
                            {% if data.step4.isBailleurAverti %}
                                Bailleur averti : {{ data.step4.isBailleurAverti|format_answer }}<br>
                            {% endif %}
                            {% if data.step4.denominationProprio %}
                                Dénomination du bailleur : {{ data.step4.denominationProprio }}<br>
                            {% endif %}
                            {% if data.step4.nomProprio %}                            
                                Nom du bailleur  : {{ data.step4.nomProprio }}<br>
                            {% endif %}
                            {% if data.step4.prenomProprio %}
                                Prénom du bailleur : {{ data.step4.prenomProprio }}<br>
                            {% endif %}
                            {% if data.step4.mailProprio %}
                                Adresse e-mail du bailleur : {{ data.step4.mailProprio }}<br>
                            {% endif %}
                            {% if data.step4.telProprio %}
                                Téléphone du bailleur : {{ data.step4.telProprio|phone }}<br>
                            {% endif %}
                        {% endif %}
                        {% if showBailleur and showSyndic %}
                            <br><hr>
                        {% endif %}
                        {% if showSyndic %}
                            <strong>Syndic</strong><br>
                            {% if data.step4.denominationSyndic %}
                                Dénomination du syndic : {{ data.step4.denominationSyndic }}<br>
                            {% endif %}
                            {% if data.step4.nomSyndic %}
                                Nom du ou de la représentante : {{ data.step4.nomSyndic }}<br>
                            {% endif %}
                            {% if data.step4.mailSyndic %}
                                Adresse e-mail  : {{ data.step4.mailSyndic }}<br>
                            {% endif %}
                            {% if data.step4.telSyndic %}
                                Téléphone : {{ data.step4.telSyndic|phone }}<br>
                            {% endif %}
                            {% if data.step4.telSyndicSecondaire %}
                                Téléphone secondaire : {{ data.step4.telSyndicSecondaire|phone }}<br>
                            {% endif %}
                        {% endif %}
                    </div>
                    
                    <div class="signalement-group-data-card">
                        <div class="fr-display-flex-row fr-justify-content-space-between fr-align-items-center">
                            <h2 class="fr-h6">Désordres</h2>
                            {{ form_row(form.navigator.editStep5) }}
                        </div>
                        {% if data.step5.autresOccupantsDesordre %}
                            Désordres rencontrés par d'autres occupants de l'immeuble : {{ data.step5.autresOccupantsDesordre|format_answer }}<br>
                        {% endif %}
                        {% if data.step5.desordres %}
                            <ul>
                            {% for desordre in desordres %}
                                {% if desordre.slugCritere in data.step5.desordres %}                                    
                                    <li>{{ desordre.labelCritere }}
                                    {% if desordre.labelCritere is same as 'Autre' and data.step5.desordresAutre %}
                                        : <br>
                                        <span class="fr-border--left-thick"><i>{{ data.step5.desordresAutre }}</i></span><br>
                                    {% endif %}
                                    </li>
                                {% endif %}
                            {% endfor %}
                            </ul>
                        {% endif %}
                    </div>

                    {{form_row(form.step6.hidden)}}
                {% endif %}
                {#
                    Ordre DOM volontaire pour la tabulation : next => previous => reset
                    L'ordre visuel est géré en CSS via les classes form-nav-row-reverse et fr-btns-group--inline-reverse
                    Ne pas modifier l'ordre HTML sans adapter aussi la navigation clavier.
                #}
                <div class="fr-col-12 fr-col-lg">
                    <div class="fr-grid-row fr-grid-row--middle fr-grid-row--gutters form-nav-row-reverse fr-mt-4w">
                        <div class="fr-col-12 fr-col-lg">
                            <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline-lg fr-btns-group--icon-left  fr-btns-group--inline-reverse">
                                {% if form.navigator.next is defined %}
                                    <li>{{ form_widget(form.navigator.next) }}</li>
                                {% endif %}
                                {% if form.navigator.nextReview is defined %}
                                    <li>{{ form_widget(form.navigator.nextReview) }}</li>
                                {% endif %}
                                {% if form.navigator.finish is defined %}
                                    <li>{{ form_widget(form.navigator.finish) }}</li>
                                {% endif %}
                                {% if form.navigator.previous is defined %}
                                    <li>{{ form_widget(form.navigator.previous) }}</li>
                                {% endif %}
                            </ul>
                        </div>
                        <div class="fr-col-12 fr-col-lg">
                            {% if form.navigator.reset is defined %}
                                <ul class="fr-btns-group fr-btns-group--inline-lg fr-btns-group--icon-left">
                                    <li>{{ form_widget(form.navigator.reset) }}</li>
                                </ul>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {{ form_end(form) }}

            </div>
        </section>
    </main>
{% endblock %}
