{% extends 'service_secours/base.html.twig' %}

{% block body %}
    <main class="fr-container fr-mb-5w" id="content">
        <section class="fr-grid-row fr-grid-row--center">
            <div class="fr-mt-5v fr-col-md-12">
                <h1>Bienvenue {{serviceSecoursRoute.name}}</h1>

                {% set current_step = form.vars.cursor.currentStep %}
                {% if current_step === 'step1' %}
                    {% set step_number = 1 %}
                    {% set step_title = 'Vos coordonnées' %}
                    {% set next_step_title = 'Infos sur le logement' %}
                {% elseif current_step === 'step2' %}
                    {% set step_number = 2 %}
                    {% set step_title = 'Infos sur le logement' %}
                    {% set next_step_title = 'Occupation du logement' %}
                {% elseif current_step === 'step3' %}
                    {% set step_number = 3 %}
                    {% set step_title = 'Occupation du logement' %}
                    {% set next_step_title = 'Propriétaire / bailleur' %}
                {% elseif current_step === 'step4' %}
                    {% set step_number = 4 %}
                    {% set step_title = 'Propriétaire / bailleur' %}
                    {% set next_step_title = 'Désordres' %}
                {% elseif current_step === 'step5' %}
                    {% set step_number = 5 %}
                    {% set step_title = 'Désordres' %}
                {% endif %}

                {% if current_step != 'step6' %}
                    <div class="fr-stepper">
                        <h2 class="fr-stepper__title">
                            {{step_title}} <span class="fr-stepper__state">Étape {{ step_number }} sur 5</span>
                        </h2>
                        <div class="fr-stepper__steps" data-fr-current-step="{{ step_number }}" data-fr-steps="5"></div>
                        {% if next_step_title is defined %}
                            <p class="fr-stepper__details">
                                <span class="fr-text--bold">Étape suivante :</span> {{ next_step_title }}
                            </p>
                        {% endif %}
                    </div>
                {% endif %}

                {{ form_start(form) }}
                {{ form_errors(form) }}

                {% if current_step == 'step1' %}
                    {{ form_row(form.step1.matriculeDeclarant) }}
                    {{ form_row(form.step1.nomDeclarant) }}
                    {{ form_row(form.step1.dateMission) }}
                    {{ form_row(form.step1.origineMission) }}
                    {{ form_row(form.step1.ordreMission) }}
                {% elseif current_step == 'step2' %}
                    {{ form_row(form.step2.adresseComplete) }}
                    {{ form_row(form.step2.adresseAutreOccupant) }}
                    {{ form_row(form.step2.isLogementSocial) }}
                    {{ form_row(form.step2.natureLogement) }}
                    {{ form_row(form.step2.typeEtageLogement) }}
                    {{ form_row(form.step2.etageOccupant) }}
                    {{ form_row(form.step2.nbPiecesLogement) }}
                    {{ form_row(form.step2.superficie) }}
                {% elseif current_step == 'step3' %}
                    {{ form_row(form.step3.profilOccupant) }}
                    {{ form_row(form.step3.nomOccupant) }}
                    {{ form_row(form.step3.prenomOccupant) }}
                    {{ form_row(form.step3.mailOccupant) }}
                    {{ form_row(form.step3.telOccupant) }}
                    {{ form_row(form.step3.nbAdultesDansLogement) }}
                    {{ form_row(form.step3.nbEnfantsDansLogement) }}
                    {{ form_row(form.step3.isEnfantsMoinsSixAnsDansLogement) }}
                    {{ form_row(form.step3.autreVulnerabilite) }}
                {% elseif current_step == 'step4' %}
                    {{ form_row(form.step4.isBailleurAverti) }}
                    {{ form_row(form.step4.denominationBailleur) }}
                    {{ form_row(form.step4.mailBailleur) }}
                    {{ form_row(form.step4.telBailleur) }}
                {% elseif current_step == 'step5' %}
                    {{ form_row(form.step5.desordres) }}
                    {{ form_row(form.step5.desordresAutre) }}
                    {{ form_row(form.step5.autresOccupantsDesordre) }}
                {% elseif current_step == 'step6' %}
                    <div class="fr-mt-5v fr-mb-5v">
                        //RECAP
                    </div>
                    {{form_row(form.step6.hidden)}}
                {% endif %}

                <div class="fr-grid-row fr-grid-row--center">
                    {% if form.navigator.previous is defined %}
                        <div class="fr-col">
                            {{ form_row(form.navigator.previous) }}
                        </div>
                    {% endif %}
                    {% if form.navigator.next is defined %}
                        <div class="fr-col fr-text--right">
                            {{ form_row(form.navigator.next) }}
                        </div>
                    {% endif %}
                    {% if form.navigator.finish is defined %}
                        <div class="fr-col fr-text--right">
                            {{ form_row(form.navigator.finish) }}
                        </div>
                    {% endif %}
                </div>

                {{ form_end(form) }}

            </div>
        </section>
    </main>
{% endblock %}
