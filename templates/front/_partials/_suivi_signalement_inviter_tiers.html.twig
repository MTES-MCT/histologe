{% if signalement.profileDeclarant is same as enum('App\\Entity\\Enum\\ProfileDeclarant').LOCATAIRE
    and not signalement.mailDeclarant
    and is_granted('SIGN_USAGER_EDIT', signalement)
%}
    <div class="fr-callout {{ cssDiv }}">
        <h{{ heading|default(4) }} class="fr-callout__title">
            {% if tiersInvitation %}Invitation en attente{% else %}Invitez un tiers{% endif %}
        </h{{ heading|default(4) }}>
        <p class="fr-callout__text fr-mb-2v">
            Afin de faciliter les échanges avec l'administration, vous pouvez donner accès au dossier à un tiers
            (famille, travailleur social, association, etc.) en renseignant son adresse e-mail.
        </p>
        {% if tiersInvitation %}
            <div class="alert alert-warning">
                <strong>Invitation en attente pour {{ tiersInvitation.email }}</strong>
            </div>
        {% else %}
            <p>
                <a href="{{ path('front_suivi_signalement_coordonnees_tiers', {code: signalement.codeSuivi}) }}"
                    class="fr-btn fr-btn--secondary fr-btn--icon-left fr-icon-edit-box-line fr-mt-3v"
                    data-matomo-clickable-event-category="Suivre mon signalement"
                    data-matomo-clickable-event-action="clickLink"
                    data-matomo-clickable-event-name="Inviter un tiers sur mon dossier"
                    >Inviter un tiers sur mon dossier</a>
            </p>
        {% endif %}
    </div>
{% endif %}