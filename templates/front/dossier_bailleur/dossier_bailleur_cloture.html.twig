{% extends 'base.html.twig' %}

{% block title %}Détails du dossier #{{ signalement.reference }}{% endblock %}

{% block body %}

<main class="fr-container fr-py-5w" id="content"
	data-matomo-scrollable-event-element="window"
	data-matomo-scrollable-event-category="Espace bailleur"
	data-matomo-scrollable-event-action="scroll"
	data-matomo-scrollable-event-name="Page"
	data-matomo-scrollable-event-value="50"
	data-matomo-timer-event-category="Suivre mon signalement"
	data-matomo-timer-event-action="timer"
	data-matomo-timer-event-name="40">
	<nav role="navigation" class="fr-breadcrumb fr-mb-1w fr-mt-2w" aria-label="Voir le fil d'Ariane">
		<button class="fr-breadcrumb__button" aria-expanded="false" aria-controls="breadcrumb-1">Voir le fil d'Ariane</button>
		<div class="fr-collapse" id="breadcrumb-1">
			<ol class="fr-breadcrumb__list">
				<li><a class="fr-breadcrumb__link" href="{{ path('front_dossier_bailleur') }}">Détails du dossier #{{ signalement.reference }}</a></li>
				<li><a class="fr-breadcrumb__link" aria-current="page">Demander l'arrêt de la procédure</a></li>
			</ol>
		</div>
	</nav>
	<div class="fr-grid-row fr-grid-row--gutters fr-grid-row--center">
		<div class="fr-col-12 fr-col-md-8">
			{{ form_start(form, {'attr': {'id': 'form-dossier-bailleur-cloture', novalidate: 'novalidate'}}) }}
			{{ form_errors(form) }}
				<h1 class="title-blue-france">Demander l'arrêt de la procédure</h1>
				<p>Vous souhaitez arrêter la procédure. Veuillez indiquer la raison.</p>
				<ul>
					<li><strong>Les travaux ont été faits.</strong> Une confirmation sera demandée à votre locataire. Tant que le locataire ne confirme pas ou n'infirme pas le dossier reste en injonction en cours.</li>
					<li><strong>Autre.</strong> Votre dossier sera transmis aux services compétents pour instruction.</li>
				</ul>
				{{ form_row(form.reason) }}
				{{ form_row(form.description) }}
				<div class="fr-grid-row fr-grid-row--gutters">
					<div class="fr-col-12 fr-pb-0">
						<ul class="fr-btns-group fr-btns-group--inline-lg fr-btns-group--icon-left fr-btns-group--right fr-btns-group--inline-reverse fr-btns-group--inline-md">
							<li>				
								<button class="fr-btn fr-icon-check-line" type="submit" form="form-dossier-bailleur-cloture">
									Valider ma demande
								</button>
							</li>
							<li>					
								<a class="fr-btn fr-btn--secondary fr-icon-close-line" href="{{ path('front_dossier_bailleur') }}" >Annuler</a>
							</li>
						</ul>
					</div>
				</div>
			{{ form_end(form) }}
		</div>
	</div>

</main>
{% endblock %}
