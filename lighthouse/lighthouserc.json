{
    "ci": {
        "collect": {
            "numberOfRuns": 1,
            "url": [
                "http://localhost:8080/connexion"
            ],
            "settings": {
                "chromeFlags": "--no-sandbox --disable-dev-shm-usage --disable-gpu",
                "output": ["html", "json"]
            }
        },
        "assert": {
            "assertions": {
                "categories:performance": "off",
                "categories:pwa": "off",
                "categories:accessibility": ["error", { "minScore": 0.95 }]
            }
        },
        "upload": {
            "target": "filesystem",
            "outputDir": ".lighthouseci"
        }
    }
}