{
    "ci": {
        "collect": {
            "numberOfRuns": 1,
            "url": [
                "http://localhost:8080/bo"
            ],
            "puppeteerScript": "./lighthouse/auth.js"
        },
        "assert": {
            "assertions": {
                "categories:performance": "off",
                "categories:pwa": "off",
                "categories:accessibility": ["error", { "minScore": 1 }]
            }
        },
        "upload": {
            "target": "filesystem",
            "outputDir": ".lighthouseci"
        }
    }
}
