parameters:
	level: 7
	paths:
		- src
		- tests
	excludePaths:
		- .php-cs-fixer.dist.php
		- tools
	symfony:
		containerXmlPath: var/cache/test/App_KernelTestDebugContainer.xml
		consoleApplicationLoader: tests/phpstan-bootstrap.php
	treatPhpDocTypesAsCertain: false
	reportUnmatchedIgnoredErrors: false
	bootstrapFiles:
		- tools/wiremock/src/Mock/AppMock.php
	ignoreErrors:
		-
			message: '#Property [a-zA-Z0-9\_]+::\$desordrePrecisionRepository is never read, only written.#'
			path: src/Service/Signalement/DesordreTraitement/*
		-
			message: '#Property .+::\$id is never written, only read.#'
			path: src/Entity/*
		# Ignore PHPStan 2.0 strictness - to be fixed gradually
		-
			identifier: doctrine.columnType #116 errors remaining
		-
			identifier: doctrine.associationType #26 errors remaining
		-
			identifier: property.unusedType #16 errors remaining
		-
			identifier: varTag.nativeType #10 errors remaining
		# PHPStan false positives with PHPUnit 13
		-
			message: '#Call to an undefined method PHPUnit\\Framework\\MockObject\\InvocationStubber::with\(\)#'
		-
			identifier: phpunit.callParent
		-
			identifier: phpunit.assertCount
		-
			identifier: method.alreadyNarrowedType
			path: tests/*
		-
			identifier: function.alreadyNarrowedType
			path: tests/*
		-
			identifier: function.alreadyNarrowedType
			path: src/*
		-
			identifier: assign.propertyType
			path: tests/*
		-
			identifier: assign.propertyType
			path: src/*
		-
			identifier: argument.templateType
		-
			identifier: offsetAccess.invalidOffset
		-
			identifier: property.notFound
			path: src/*
		-
			identifier: empty.variable
		-
			identifier: argument.named
